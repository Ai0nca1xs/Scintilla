---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/i18n/utils';

const t = useTranslations('FR');
---

<BaseLayout title={t.gallery.pageTitle}>
	<header class="page-header">
		<h1 class="title-calx">{t.gallery.heading}</h1>
		<p class="metadata">AUDIO / PHOTOGRAPHY / PAINTING / WRITING</p>
	</header>

	<section class="portfolio-grid">
		<div class="placeholder-card">[MEDIA CAROUSEL SPACEHOLDER]</div>
	</section>
</BaseLayout>

<style>
	.placeholder-card {
		border: 1px dashed rgba(26, 26, 26, 0.2);
		height: 400px;
		display: grid;
		place-items: center;
		opacity: 0.5;
	}
</style>
