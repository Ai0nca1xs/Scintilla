---
// 首頁主體內容，EN / FR 兩個頁面共用，文字全部來自 i18n 詞典。
import { getCollection } from 'astro:content';
import { localizePath, useTranslations, type Lang } from '@/i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// 精選作品：從 projects collection 取 featured 條目，按 order 排序，首頁最多展示 5 件
const localePrefix = lang === 'FR' ? 'fr/' : 'en/';
const featured = (
	await getCollection('projects', ({ id, data }) => id.startsWith(localePrefix) && data.featured)
)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 5);
---

<section class="hero-section">
	<h1 class="hero-title title-calx">SCINTILLA</h1>
	<div class="metadata">{t.home.heroMeta}</div>
</section>

<section class="concept-intro">
	<p>{t.home.concept}</p>
</section>

<section class="personal-intro">
	<p set:html={t.home.introHtml} />
</section>

<section class="work-section">
	<div>
		<h3 class="section-label">{t.home.capabilitiesLabel}</h3>
		<ul class="capabilities-list">
			{t.home.capabilities.map((item) => <li>{item}</li>)}
		</ul>
	</div>

	<div>
		<h3 class="section-label">{t.home.selectedLabel}</h3>
		<ul class="projects-list">
			{
				featured.map((entry) => (
					<li>
						<a
							href={localizePath(lang, `/project/${entry.id.replace(/^(en|fr)\//, '')}`)}
							class="project-item"
						>
							<span class="project-name">
								{entry.data.title} <span class="metadata">{entry.data.code}</span>
							</span>
							<span class="project-tags">
								{entry.data.tags.map((tag) => `[${tag}]`).join(' ')}
							</span>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>

<section class="gallery-section">
	<h3 class="section-label">{t.home.galleryLabel}</h3>
	<p class="gallery-text">{t.home.galleryText}</p>
	<a href={localizePath(lang, '/gallery')} class="title-calx gallery-cta">{t.home.galleryCta}</a>
</section>

<!-- hero 標題的「液態金屬」SVG 濾鏡（全頁僅此一份定義） -->
<svg style="display: none;" aria-hidden="true">
	<defs>
		<filter id="liquid-filter" x="-20%" y="-20%" width="140%" height="140%">
			<feTurbulence
				type="fractalNoise"
				baseFrequency="0"
				numOctaves="2"
				result="noise"
				id="turbulence"></feTurbulence>
			<feDisplacementMap
				in="SourceGraphic"
				in2="noise"
				scale="0"
				xChannelSelector="R"
				yChannelSelector="G"
				id="displacement"></feDisplacementMap>
		</filter>
	</defs>
</svg>

<style>
	/* --- 首頁專屬佈局 (Homepage Specific Layout) --- */

	/* 1. 首屏概念區 (Hero Section) */
	.hero-section {
		min-height: 70vh; /* 佔據螢幕 70% 高度，留出呼吸空間 */
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		margin-bottom: var(--space-lg);
	}

	.hero-title {
		font-size: clamp(2.5rem, 8vw, 4.5rem); /* 巨大化標題，隨視窗寬度縮放 */
		font-weight: 800;
		margin-bottom: 0.5rem;
		letter-spacing: 0.05em;

		/* 綁定下方定義的 SVG 濾鏡 */
		filter: url(#liquid-filter);

		/* 微 3D 處理：利用多層低透明度陰影模擬物體厚度與光暈 */
		text-shadow:
			0px 4px 15px rgba(26, 26, 26, 0.1),
			0px 1px 2px rgba(255, 255, 255, 0.5);

		transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
		will-change: filter, transform; /* 提示瀏覽器預先配置 GPU 資源 */
	}

	.concept-intro {
		font-size: 14px;
		max-width: 500px;
		margin: 0 auto var(--space-lg);
		text-align: center;
		color: rgba(26, 26, 26, 0.6);
	}

	/* 2. 個人簡介區 (Introduction) */
	.personal-intro {
		max-width: 720px;
		margin: 0 auto calc(var(--space-lg) * 2);
	}

	/* 3. 核心能力與作品區塊 (2:3 Split Layout) */
	.work-section {
		display: grid;
		grid-template-columns: 2fr 3fr; /* 實踐 2/5 與 3/5 的精確分割 */
		gap: var(--space-lg);
		margin-bottom: calc(var(--space-lg) * 2);
	}

	/* 能力列表 (Capabilities) */
	.capabilities-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.capabilities-list li {
		margin-bottom: 0.8rem;
		font-weight: 400;
	}

	/* 專案列表 (Selected Projects) */
	.projects-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.project-item {
		display: flex;
		flex-direction: column;
		padding-bottom: 1rem;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid rgba(26, 26, 26, 0.1);
		transition: border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
	}

	/* 結合之前討論的「氧化」微互動 */
	.project-item:hover {
		border-color: #ffd700;
		opacity: 1; /* 覆蓋 global 中 a 標籤預設的 0.6 透明度 */
	}

	.project-name {
		font-size: 16px;
		font-weight: 400;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.project-tags {
		font-family: monospace;
		font-size: 10px;
		opacity: 0.5;
		margin-top: 0.4rem;
	}

	/* 4. 個人美學入口 (Gallery Link) */
	.gallery-section {
		text-align: center;
		padding-top: var(--space-lg);
		padding-bottom: calc(var(--space-lg) * 2);
		border-top: 1px solid rgba(26, 26, 26, 0.05);
	}

	.gallery-text {
		margin-bottom: 1.5rem;
		opacity: 0.8;
	}

	.gallery-cta {
		font-size: 14px;
		font-weight: 500;
	}

	/* 響應式設計：在手機版自動切換為上下排列 */
	@media (max-width: 768px) {
		.work-section {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	// hero 標題的「液態加熱」互動。
	// 使用 astro:page-load 事件：搭配 ClientRouter，它在首次載入與每次換頁後都會觸發，
	// 確保轉場後新的 DOM 元素也能正確綁定監聽。
	let animationFrameId: number;

	function initHeroLiquid() {
		const title = document.querySelector('.hero-title') as HTMLElement | null;
		const turbulence = document.querySelector('#turbulence');
		const displacement = document.querySelector('#displacement');

		// 檢查系統的「減少動態效果」設定
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (!title || !turbulence || !displacement || prefersReducedMotion) return;

		let phase = 0;
		let currentScale = 0; // 當前扭曲強度
		let targetScale = 0; // 目標扭曲強度

		const animateLiquid = () => {
			phase += 0.05;
			const freqX = 0.015;
			const freqY = 0.015 + Math.sin(phase) * 0.005;
			turbulence.setAttribute('baseFrequency', `${freqX} ${freqY}`);

			// 核心：線性插值 (Lerp)，讓當前值以 8% 的速度緩慢逼近目標值
			currentScale += (targetScale - currentScale) * 0.08;
			displacement.setAttribute('scale', currentScale.toString());

			// 當滑鼠離開，且冷卻到肉眼看不見形變時，停止動畫以節省效能
			if (targetScale === 0 && currentScale < 0.1) {
				currentScale = 0;
				displacement.setAttribute('scale', '0');
				cancelAnimationFrame(animationFrameId);
				return;
			}

			animationFrameId = requestAnimationFrame(animateLiquid);
		};

		title.addEventListener('mouseenter', () => {
			targetScale = 12; // 加熱：設定目標為 12
			cancelAnimationFrame(animationFrameId);
			animateLiquid();
			title.style.transform = 'scale(1.02) translateY(-2px)';
		});

		title.addEventListener('mouseleave', () => {
			targetScale = 0; // 冷卻：設定目標為 0，讓 Lerp 自動處理緩降
			title.style.transform = 'scale(1) translateY(0)';
		});
	}

	document.addEventListener('astro:page-load', initHeroLiquid);
	// 換頁前停掉動畫循環，避免殘留的 rAF 引用舊頁面的元素
	document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animationFrameId));
</script>
