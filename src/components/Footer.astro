---
// 檔案館式落款：版權 + 「最後校準」時間戳（構建時自動生成）
const now = new Date();
const year = now.getFullYear();
const calibrated = `${year}.${String(now.getMonth() + 1).padStart(2, '0')}`;
---

<footer class="site-footer">
	<span>&copy; {year} Qianyu</span>
	<span class="metadata">SCINTILLA · LAST CALIBRATED {calibrated}</span>
</footer>

<style>
	.site-footer {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		max-width: var(--container-max-width);
		margin: 0 auto;
		padding: 2rem 8px 3rem;
		border-top: 1px solid rgba(26, 26, 26, 0.08);
		font-size: 10px;
		letter-spacing: 0.05em;
		opacity: 0.6;
	}
</style>
