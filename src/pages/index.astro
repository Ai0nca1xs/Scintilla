---
// 根路徑重定向到預設語言（EN）。withBase 確保在 GitHub Pages 子路徑下也能正確跳轉。
import { withBase } from '@/i18n/utils';

const target = withBase('/EN/');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta http-equiv="refresh" content={`0;url=${target}`} />
		<link rel="canonical" href={target} />
		<title>Scintilla</title>
	</head>
	<body></body>
</html>
