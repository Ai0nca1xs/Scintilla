---
import { getCollection } from 'astro:content';
import ProjectDetail from '@/components/ProjectDetail.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const entries = await getCollection('projects', ({ id }) => id.startsWith('en/'));
	return entries.map((entry) => ({
		params: { slug: entry.id.replace(/^en\//, '') },
		props: { entry },
	}));
}

const { entry } = Astro.props;
---

<BaseLayout title={`${entry.data.title} — Scintilla`} description={entry.data.summary}>
	<ProjectDetail entry={entry} lang="EN" />
</BaseLayout>
