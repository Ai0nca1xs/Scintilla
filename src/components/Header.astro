---
import { getLangFromUrl, getLangSwitchUrl, localizePath, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="site-header">
	<div class="nav-left">
		<h2><a href={localizePath(lang, '/')}>{t.site.tagline}</a></h2>
	</div>

	<nav class="nav-right">
		<div class="lang-switch">
			<a
				href={lang === 'EN' ? '#' : getLangSwitchUrl(Astro.url, 'EN')}
				class={lang === 'EN' ? 'active' : ''}>EN</a
			>
			<span class="separator">/</span>
			<a
				href={lang === 'FR' ? '#' : getLangSwitchUrl(Astro.url, 'FR')}
				class={lang === 'FR' ? 'active' : ''}>FR</a
			>
		</div>

		<ul class="nav-links">
			<li><a href={localizePath(lang, '/')}>{t.nav.home}</a></li>
			<li><a href={localizePath(lang, '/project')}>{t.nav.project}</a></li>
			<li><a href={localizePath(lang, '/gallery')}>{t.nav.gallery}</a></li>
			<li><a href={localizePath(lang, '/contact')}>{t.nav.contact}</a></li>
		</ul>
	</nav>
</header>

<style>
	/* 1. 容器佈局 */
	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline; /* 確保左右兩側文字底部完全對齊 */
		max-width: var(--container-max-width);
		margin: 0 auto;
		padding-top: 1.2rem;
		padding-bottom: 1.2rem;
		padding-left: 8px;
		padding-right: 8px;
	}

	/* 2. 文字基礎設定 */
	.site-header h2,
	.site-header a,
	.site-header span {
		font-size: 11px;
		font-weight: 300;
		letter-spacing: 0.05em;
		margin: 0;
		line-height: 2.5;
		text-transform: uppercase;
	}

	/* 3. 右側導覽群組佈局 */
	.nav-right {
		display: flex;
		align-items: baseline; /* 確保語系與導覽列文字底部對齊 */
		gap: 2.3rem;
	}

	/* 4. 語系切換 */
	.lang-switch {
		display: flex;
		align-items: baseline;
		gap: 0.25rem;
	}
	.lang-switch .separator {
		opacity: 0.3;
	}
	.lang-switch a {
		opacity: 0.5;
		transition: opacity 0.2s ease;
	}
	.lang-switch a.active,
	.lang-switch a:hover {
		opacity: 1;
	}

	/* 5. 導覽列與氧化互動邏輯 */
	.nav-links {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 1.5rem;
	}

	.nav-links a {
		display: inline-block; /* 必須設定為 inline-block 才能讓 transform 縮放生效 */
		opacity: 0.6;
		transition: all 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
		transform-origin: center;
	}

	/* 觸發條件 A：當游標懸停在整個導覽列 ul 上時，將所有 a 標籤模糊、變暗、微縮 */
	.nav-links:hover a {
		filter: blur(1px);
		opacity: 0.2;
		transform: scale(0.95);
	}

	/* 觸發條件 B：針對被直接懸停的特定 a 標籤，解除限制並套用氧化視覺 */
	.nav-links a:hover {
		filter: blur(0);
		opacity: 1;
		transform: scale(1.15); /* 放大文字 */

		/* 套用全域定義的煅燒漸層變數 */
		background: var(--calx-gradient);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
</style>
